{
  "name": "auto-typer-extension",
  "version": "0.1.0",
  "description": "Auto-typer browser extension - inject text into any website input field",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "plasmo": "0.89.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "lucide-react": "^0.439.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.3.3"
  },
  "manifest": {
    "name": "Auto Typer",
    "description": "Inject text into any website input field instantly",
    "version": "0.1.0",
    "permissions": [
      "activeTab",
      "storage",
      "scripting",
      "sidePanel"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "commands": {
      "inject-last-text": {
        "suggested_key": {
          "default": "Ctrl+Shift+Space",
          "mac": "Command+Shift+Space"
        },
        "description": "Inject last text into focused field"
      },
      "toggle-picker": {
        "suggested_key": {
          "default": "Ctrl+Shift+E",
          "mac": "Command+Shift+E"
        },
        "description": "Toggle field picker mode"
      }
    },
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
